{
  "name": "axios-auth-client",
  "version": "1.2.0",
  "description": "A lightweight, framework-agnostic Axios wrapper with automatic JWT access token refresh (proactive + reactive), 401 retry logic, and custom refresh support.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "axios",
    "auth",
    "jwt",
    "token-refresh",
    "authentication",
    "http-client",
    "typescript"
  ],
  "author": "Usama Imran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/UsamaImran/axios-auth-client"
  },
  "bugs": {
    "url": "https://github.com/UsamaImran/axios-auth-client/issues"
  },
  "homepage": "https://github.com/UsamaImran/axios-auth-client",
  "peerDependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "axios": "^1.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
